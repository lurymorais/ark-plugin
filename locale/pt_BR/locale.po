msgid "plugins.pubIds.ark.displayName"
msgstr "ARK"

msgid "plugins.pubIds.ark.description"
msgstr "Plugin para atribuir identificadores ARK (Archival Resource Key) aos artigos e edições."

msgid "plugins.pubIds.ark.manager.settings.description"
msgstr "Configure o plugin ARK:"

msgid "plugins.pubIds.ark.manager.settings.arkObjects"
msgstr "Tipos de conteúdo"

msgid "plugins.pubIds.ark.manager.settings.arkObjectsRequired"
msgstr "Selecione pelo menos um tipo de conteúdo (Artigos ou Edições) para atribuir ARKs."

msgid "plugins.pubIds.ark.manager.settings.explainARKs"
msgstr "Selecione os tipos de conteúdo que receberão ARK:"

msgid "plugins.pubIds.ark.manager.settings.enablePublicationARK"
msgstr "Artigos"

msgid "plugins.pubIds.ark.manager.settings.enableIssueARK"
msgstr "Edições"

msgid "plugins.pubIds.ark.manager.settings.arkPrefix"
msgstr "Prefixo ARK"

msgid "plugins.pubIds.ark.manager.settings.arkPrefix.description"
msgstr "Prefixo fixo do ARK (ex: ark:12345)."

msgid "plugins.pubIds.ark.manager.settings.form.arkPrefixPattern"
msgstr "O prefixo deve conter 2-40 caracteres (letras, números, :, _)."

msgid "plugins.pubIds.ark.manager.settings.arkSuffix"
msgstr "Formato do sufixo"

msgid "plugins.pubIds.ark.manager.settings.arkSuffix.description"
msgstr "Configure como o sufixo do ARK será gerado."

msgid "plugins.pubIds.ark.manager.settings.arkSuffixRandom"
msgstr "Sufixo aleatório (ex: CRL1234-ABCD)"

msgid "plugins.pubIds.ark.manager.settings.arkCustomPrefix"
msgstr "Prefixo personalizado:"

msgid "plugins.pubIds.ark.manager.settings.arkCustomPrefix.validation"
msgstr "(2-6 letras maiúsculas)"

msgid "plugins.pubIds.ark.manager.settings.form.arkCustomPrefixPattern"
msgstr "O prefixo personalizado deve conter 2-6 letras maiúsculas."

msgid "plugins.pubIds.ark.manager.settings.arkResolver"
msgstr "URL do resolvedor"

msgid "plugins.pubIds.ark.manager.settings.arkResolver.description"
msgstr "URL base para resolução dos ARKs (ex: https://n2t.net/)"

msgid "plugins.pubIds.ark.manager.settings.form.arkResolverRequired"
msgstr "Informe a URL do resolvedor."

msgid "plugins.pubIds.ark.manager.settings.arkResolver.n2t"
msgstr "n2t.net (Padrão)"

msgid "plugins.pubIds.ark.manager.settings.arkResolver.custom"
msgstr "Resolvedor personalizado:"

msgid "plugins.pubIds.ark.manager.settings.arkResolver.customUrl"
msgstr "URL do resolvedor personalizado"

msgid "plugins.pubIds.ark.manager.settings.arkResolver.defaultHint"
msgstr "Deixe em branco para usar o resolvedor padrão n2t.net"

msgid "plugins.pubIds.ark.manager.settings.preview"
msgstr "Pré-visualização"

msgid "plugins.pubIds.ark.manager.settings.previewLabel"
msgstr "Exemplo de ARK que será gerado:"

msgid "plugins.pubIds.ark.manager.settings.arkReassign"
msgstr "Reatribuir ARKs"

msgid "plugins.pubIds.ark.manager.settings.arkReassign.description"
msgstr "Clique para remover todos os ARKs existentes e reatribuir com as novas configurações."

msgid "plugins.pubIds.ark.manager.settings.arkReassign.confirm"
msgstr "Tem certeza? Todos os ARKs existentes serão permanentemente removidos."

msgid "plugins.pubIds.ark.manager.settings.arkImplementationDate"
msgstr "Data de Implementação do ARK"

msgid "plugins.pubIds.ark.manager.settings.arkImplementationDate.description"
msgstr "Insira a data em que os identificadores ARK começaram a ser usados no seu periódico."

msgid "plugins.pubIds.ark.manager.settings.arkImplementationDate.recommendation"
msgstr "Se este for o seu primeiro uso do ARK, insira a data que recebeu seu NAAN ou a data de publicação do primeiro ARK."

msgid "plugins.pubIds.ark.manager.settings.form.arkImplementationDatePattern"
msgstr "A data deve estar no formato AAAAMMDD (ano, mês, dia) com 8 dígitos."

msgid "plugins.pubIds.ark.editor.ark"
msgstr "ARK"

msgid "plugins.pubIds.ark.editor.arkHelp"
msgstr "O ARK (Archival Resource Key) é um identificador persistente. Clique em 'Gerar ARK' para criar um novo identificador automaticamente."

msgid "plugins.pubIds.ark.editor.missingPrefix"
msgstr "O ARK deve começar com {$arkPrefix}."

msgid "plugins.pubIds.ark.editor.invalidSuffixFormat"
msgstr "Formato inválido. Use: {$format}"

msgid "plugins.pubIds.ark.editor.arkSuffixNotUnique"
msgstr "Este ARK já está em uso. Clique em \"Gerar ARK\" para criar um novo."

msgid "plugins.pubIds.ark.editor.clearObjectsARK"
msgstr "Limpar ARK"

msgid "plugins.pubIds.ark.editor.clearObjectsARK.confirm"
msgstr "Remover este ARK permanentemente?"

msgid "plugins.pubIds.ark.editor.assignARK"
msgstr "Atribuir o ARK {$pubId} a este {$pubObjectType}"

msgid "plugins.pubIds.ark.editor.ark.assignArk"
msgstr "Atribuir"

msgid "plugins.pubIds.ark.editor.ark.clearArk"
msgstr "Limpar"

msgid "plugins.pubIds.ark.editor.generateArk"
msgstr "Gerar ARK"

msgid "plugins.pubIds.ark.editor.generateNewArk"
msgstr "Gerar Novo ARK"

msgid "plugins.pubIds.ark.editor.generateNewArk.confirmReplace"
msgstr "Isto irá substituir o ARK existente: %s. Tem certeza que deseja gerar um novo? O ARK antigo será sobrescrito quando você salvar."

msgid "plugins.pubIds.ark.editor.generateNewArk.confirmNew"
msgstr "Gerar um novo ARK para esta edição?"

msgid "plugins.pubIds.ark.editor.duplicateArkError"
msgstr "ERRO: Este ARK já está em uso por outro artigo ou edição! Use o botão 'Gerar Novo ARK' para criar um identificador único."

msgid "plugins.pubIds.ark.editor.saveSuccess"
msgstr "ARK salvo com sucesso!"

msgid "plugins.pubIds.ark.editor.networkError"
msgstr "Erro de rede. Tente novamente."

msgid "plugins.pubIds.ark.editor.genericError"
msgstr "Erro ao salvar ARK: "

msgid "plugins.pubIds.ark.suffix.random"
msgstr "Sufixo aleatório"

msgid "common.saving"
msgstr "Salvando..."

msgid "plugins.pubIds.ark.validation.naanAlreadyUsed"
msgstr "Este identificador NAAN já está sendo usado por outra revista. Se você é o proprietário legítimo, clique no botão abaixo para verificar sua propriedade. Caso contrário, entre em contato pelo e-mail m.luryhortencio@gmail.com"

msgid "plugins.pubIds.ark.recovery.title"
msgstr "Verificação de Propriedade"

msgid "plugins.pubIds.ark.recovery.instructions"
msgstr "Para confirmar que você é o proprietário deste NAAN, clique no botão abaixo. O sistema verificará automaticamente se o domínio cadastrado no NAAN corresponde ao seu site atual."

msgid "plugins.pubIds.ark.recovery.button"
msgstr "Verificar Propriedade"

msgid "plugins.pubIds.ark.recovery.failed"
msgstr "Não foi possível verificar sua propriedade. Certifique-se de que seu NAAN está registrado corretamente."

msgid "plugins.pubIds.ark.recovery.rateLimit"
msgstr "Aguarde {$minutes} minutos antes de tentar novamente."

msgid "plugins.pubIds.ark.settings.telemetryLevel"
msgstr "Compartilhamento de dados"

msgid "plugins.pubIds.ark.settings.telemetryLevel.restricted"
msgstr "Básico (apenas dados técnicos)"

msgid "plugins.pubIds.ark.settings.telemetryLevel.public"
msgstr "Completo (compartilha dados da revista)"

msgid "plugins.pubIds.ark.manager.settings.telemetryLevel.description"
msgstr "Escolha o que deseja compartilhar para nos ajudar a melhorar o plugin:"

msgid "plugins.pubIds.ark.manager.settings.telemetryLevel.restricted.description"
msgstr "Compartilha apenas identificador NAAN, quantidade de ARKs, versão do plugin e URL do site"

msgid "plugins.pubIds.ark.manager.settings.telemetryLevel.public.description"
msgstr "Compartilha nome da revista, país, e-mail e idioma, além dos dados básicos"

msgid "plugins.pubIds.ark.manager.settings.telemetryInfo"
msgstr "Compartilhar esses dados nos ajuda a evitar fraudes e melhorar o serviço. Seus dados são protegidos conforme a LGPD."

msgid "plugins.pubIds.ark.manager.settings.publicInfo.title"
msgstr "Modo Completo Ativado"

msgid "plugins.pubIds.ark.manager.settings.publicInfo.description"
msgstr "O nome da sua revista e a quantidade de ARKs gerados aparecerão nas estatísticas públicas do ecossistema."

msgid "plugins.pubIds.ark.manager.settings.publicInfo.dataSent"
msgstr "Dados públicos: Nome da revista e quantidade de ARKs. Seus dados de contato são usados apenas internamente."

msgid "plugins.pubIds.ark.recovery.title"
msgstr "Área de Segurança"

msgid "plugins.pubIds.ark.recovery.securityArea"
msgstr "Área de Segurança"

msgid "plugins.pubIds.ark.recovery.securityNote"
msgstr "Esta área é usada APENAS se você recebeu a mensagem de que seu NAAN já está em uso. Aqui você pode comprovar que é o proprietário legítimo."

msgid "plugins.pubIds.ark.recovery.button"
msgstr "Verificar Minha Propriedade"

msgid "plugins.pubIds.ark.recovery.howItWorks"
msgstr "Como a verificação funciona:"

msgid "plugins.pubIds.ark.recovery.step1"
msgstr "Verificamos o endereço (domínio) cadastrado no seu NAAN"

msgid "plugins.pubIds.ark.recovery.step2"
msgstr "Comparamos com o endereço atual do seu site"

msgid "plugins.pubIds.ark.recovery.step3"
msgstr "Se forem iguais, seu acesso é liberado automaticamente"

msgid "plugins.pubIds.ark.recovery.step4"
msgstr "Se forem diferentes, você precisará atualizar o cadastro do seu NAAN"

msgid "plugins.pubIds.ark.recovery.targetHintLabel"
msgstr "Endereço correto para cadastrar no NAAN:"

msgid "plugins.pubIds.ark.recovery.failed"
msgstr "Não foi possível verificar sua propriedade. Verifique se seu NAAN está registrado corretamente."

msgid "plugins.pubIds.ark.recovery.success"
msgstr "Propriedade confirmada! Seu acesso foi restaurado com sucesso."

msgid "plugins.pubIds.ark.recovery.domainMismatch"
msgstr "O endereço registrado para este NAAN é diferente do seu site atual. Para corrigir, acesse o site da ARK Alliance e atualize seu cadastro para o endereço mostrado abaixo."

msgid "plugins.pubIds.ark.recovery.metadataFailed"
msgstr "Não foi possível verificar os metadados do seu NAAN. Verifique se ele está registrado corretamente."

msgid "plugins.pubIds.ark.recovery.rateLimit"
msgstr "⏱Aguarde {$minutes} minutos antes de tentar novamente."

msgid "plugins.pubIds.ark.recovery.noNaan"
msgstr "Nenhum NAAN configurado. Configure o prefixo ARK primeiro."

msgid "plugins.pubIds.ark.recovery.error.pluginNotFound"
msgstr "Erro interno: Plugin ARK não encontrado. Entre em contato com o administrador do sistema."

msgid "plugins.pubIds.ark.recovery.error.noContext"
msgstr "Erro interno: Contexto da revista não encontrado. Entre em contato com o administrador do sistema."

msgid "plugins.pubIds.ark.recovery.error.network"
msgstr "Erro de rede: Não foi possível conectar ao servidor n2t.net. Detalhe: {$error}. Verifique sua conexão com a internet."

msgid "plugins.pubIds.ark.recovery.error.naanNotFound"
msgstr "NAAN '{$naan}' não encontrado no sistema n2t.net. Verifique se ele foi registrado corretamente na ARK Alliance."

msgid "plugins.pubIds.ark.recovery.error.httpError"
msgstr "Servidor n2t.net retornou erro HTTP {$code}. Tente novamente mais tarde."

msgid "plugins.pubIds.ark.recovery.error.emptyResponse"
msgstr "Resposta vazia do servidor n2t.net. Tente novamente mais tarde."

msgid "plugins.pubIds.ark.recovery.error.invalidJson"
msgstr "Resposta inválida do servidor n2t.net. O formato dos dados não é reconhecido."

msgid "plugins.pubIds.ark.recovery.error.missingWhere"
msgstr "Metadados do NAAN incompletos. O campo 'where' (endereço do site) não foi encontrado."

msgid "plugins.pubIds.ark.recovery.noNaan"
msgstr "Nenhum NAAN configurado. Primeiro, configure o prefixo ARK nas configurações do plugin."

msgid "plugins.pubIds.ark.recovery.rateLimit"
msgstr "⏱Você já tentou verificar recentemente. Aguarde {$minutes} minutos antes de tentar novamente."

msgid "plugins.pubIds.ark.recovery.success"
msgstr "Propriedade confirmada! Seu acesso foi restaurado com sucesso para o NAAN {$naan}."

msgid "plugins.pubIds.ark.recovery.domainMismatch"
msgstr "O endereço registrado para este NAAN é '{$registered}', mas seu site atual é '{$current}'.\n\nPara corrigir, acesse o formulário da ARK Alliance e atualize seu NAAN para:\n{$target}\n\nApós atualizar, clique novamente em 'Verificar Propriedade'."

msgid "plugins.pubIds.ark.validation.naanNotFound"
msgstr "O NAAN {$naan} não está registrado na ARK Alliance. Registre-se em: https://forms.gle/2a8HQUNJRAcvq5UGA"

msgid "plugins.pubIds.ark.validation.domainMismatch"
msgstr "O domínio registrado para este NAAN é '{$registered}', mas seu site é '{$current}'. Para usar este NAAN, atualize seu cadastro na ARK Alliance."

msgid "plugins.pubIds.ark.validation.telemetryFailed"
msgstr "Não foi possível completar a validação. Tente novamente mais tarde."

msgid "plugins.pubIds.ark.recovery.waitMessage"
msgstr "Aguarde {$minutes} minutos antes de tentar novamente."

msgid "plugins.pubIds.ark.validation.invalidNaan"
msgstr "Formato de NAAN inválido. Use 'ark:12345' ou apenas o número."

msgid "plugins.pubIds.ark.validation.naanNotFound"
msgstr "O NAAN '{$naan}' não foi encontrado no registro da ARK Alliance. Registre-o em: https://forms.gle/2a8HQUNJRAcvq5UGA"

msgid "plugins.pubIds.ark.validation.domainMismatch"
msgstr "Este NAAN pertence ao domínio '{$registered}', mas seu site está em '{$current}'. Para usar este NAAN, atualize seu cadastro na ARK Alliance."

msgid "plugins.pubIds.ark.validation.telemetryFailed"
msgstr "Falha na comunicação com o servidor de telemetria. Tente novamente mais tarde."