msgid "plugins.pubIds.ark.displayName"
msgstr "ARK"

msgid "plugins.pubIds.ark.description"
msgstr "Plugin para atribuir identificadores ARK (Archival Resource Key) aos artigos e edições."

msgid "plugins.pubIds.ark.manager.settings.description"
msgstr "Configure o plugin ARK:"

msgid "plugins.pubIds.ark.manager.settings.arkObjects"
msgstr "Tipos de conteúdo"

msgid "plugins.pubIds.ark.manager.settings.arkObjectsRequired"
msgstr "Selecione pelo menos um tipo de conteúdo (Artigos ou Edições) para atribuir ARKs."

msgid "plugins.pubIds.ark.manager.settings.explainARKs"
msgstr "Selecione os tipos de conteúdo que receberão ARK:"

msgid "plugins.pubIds.ark.manager.settings.enablePublicationARK"
msgstr "Artigos"

msgid "plugins.pubIds.ark.manager.settings.enableIssueARK"
msgstr "Edições"

msgid "plugins.pubIds.ark.manager.settings.arkPrefix"
msgstr "Prefixo ARK (NAAN)"

msgid "plugins.pubIds.ark.manager.settings.arkPrefix.description"
msgstr "Seu prefixo NAAN (ex: ark:12345). Este deve ser registrado na ARK Alliance."

msgid "plugins.pubIds.ark.manager.settings.form.arkPrefixPattern"
msgstr "O prefixo deve conter 2-40 caracteres (letras, números, :, _)."

msgid "plugins.pubIds.ark.manager.settings.arkSuffix"
msgstr "Formato do sufixo"

msgid "plugins.pubIds.ark.manager.settings.arkSuffix.description"
msgstr "Configure como o sufixo do ARK será gerado."

msgid "plugins.pubIds.ark.manager.settings.arkSuffixRandom"
msgstr "Sufixo aleatório (ex: CRL1234-ABCD)"

msgid "plugins.pubIds.ark.manager.settings.arkCustomPrefix"
msgstr "Prefixo personalizado:"

msgid "plugins.pubIds.ark.manager.settings.arkCustomPrefix.validation"
msgstr "(2-6 letras maiúsculas)"

msgid "plugins.pubIds.ark.manager.settings.form.arkCustomPrefixPattern"
msgstr "O prefixo personalizado deve conter 2-6 letras maiúsculas."

msgid "plugins.pubIds.ark.manager.settings.arkResolver"
msgstr "URL do resolvedor"

msgid "plugins.pubIds.ark.manager.settings.arkResolver.description"
msgstr "URL base para resolução dos ARKs (ex: https://n2t.net/)"

msgid "plugins.pubIds.ark.manager.settings.form.arkResolverRequired"
msgstr "Informe a URL do resolvedor."

msgid "plugins.pubIds.ark.manager.settings.arkResolver.n2t"
msgstr "n2t.net (Padrão)"

msgid "plugins.pubIds.ark.manager.settings.arkResolver.custom"
msgstr "Resolvedor personalizado:"

msgid "plugins.pubIds.ark.manager.settings.arkResolver.customUrl"
msgstr "URL do resolvedor personalizado"

msgid "plugins.pubIds.ark.manager.settings.arkResolver.defaultHint"
msgstr "Deixe em branco para usar o resolvedor padrão n2t.net"

msgid "plugins.pubIds.ark.manager.settings.preview"
msgstr "Pré-visualização"

msgid "plugins.pubIds.ark.manager.settings.previewLabel"
msgstr "Exemplo de ARK que será gerado:"

msgid "plugins.pubIds.ark.manager.settings.arkReassign"
msgstr "Reatribuir ARKs"

msgid "plugins.pubIds.ark.manager.settings.arkReassign.description"
msgstr "Clique para remover todos os ARKs existentes e reatribuir com as novas configurações."

msgid "plugins.pubIds.ark.manager.settings.arkReassign.confirm"
msgstr "Tem certeza? Todos os ARKs existentes serão permanentemente removidos."

msgid "plugins.pubIds.ark.manager.settings.arkImplementationDate"
msgstr "Data de Implementação do ARK"

msgid "plugins.pubIds.ark.manager.settings.arkImplementationDate.description"
msgstr "Insira a data em que os identificadores ARK começaram a ser usados no seu periódico."

msgid "plugins.pubIds.ark.manager.settings.arkImplementationDate.recommendation"
msgstr "Se este for o seu primeiro uso do ARK, insira a data que recebeu seu NAAN ou a data de publicação do primeiro ARK."

msgid "plugins.pubIds.ark.manager.settings.form.arkImplementationDatePattern"
msgstr "A data deve estar no formato AAAAMMDD (ano, mês, dia) com 8 dígitos."

msgid "plugins.pubIds.ark.manager.settings.telemetryEnabled"
msgstr "Enviar estatísticas anônimas"

msgid "plugins.pubIds.ark.manager.settings.telemetryEnabled.description"
msgstr "Ajude a melhorar o plugin compartilhando dados anônimos de uso."

msgid "plugins.pubIds.ark.manager.settings.telemetryEnabled.help"
msgstr "Dados enviados: NAAN, quantidade de ARKs, versão do plugin. Nenhum dado pessoal é coletado. Saiba mais na Política de Privacidade."

msgid "plugins.pubIds.ark.editor.ark"
msgstr "ARK"

msgid "plugins.pubIds.ark.editor.arkHelp"
msgstr "O ARK (Archival Resource Key) é um identificador persistente. Clique em 'Gerar ARK' para criar um novo identificador automaticamente."

msgid "plugins.pubIds.ark.editor.missingPrefix"
msgstr "O ARK deve começar com {$arkPrefix}."

msgid "plugins.pubIds.ark.editor.invalidSuffixFormat"
msgstr "Formato inválido. Use: {$format}"

msgid "plugins.pubIds.ark.editor.arkSuffixNotUnique"
msgstr "Este ARK já está em uso. Clique em \"Gerar ARK\" para criar um novo."

msgid "plugins.pubIds.ark.editor.clearObjectsARK"
msgstr "Limpar ARK"

msgid "plugins.pubIds.ark.editor.clearObjectsARK.confirm"
msgstr "Remover este ARK permanentemente?"

msgid "plugins.pubIds.ark.editor.assignARK"
msgstr "Atribuir o ARK {$pubId} a este {$pubObjectType}"

msgid "plugins.pubIds.ark.editor.ark.assignArk"
msgstr "Atribuir"

msgid "plugins.pubIds.ark.editor.ark.clearArk"
msgstr "Limpar"

msgid "plugins.pubIds.ark.editor.generateArk"
msgstr "Gerar ARK"

msgid "plugins.pubIds.ark.editor.generateNewArk"
msgstr "Gerar Novo ARK"

msgid "plugins.pubIds.ark.editor.generateNewArk.confirmReplace"
msgstr "Isto irá substituir o ARK existente: %s. Tem certeza que deseja gerar um novo? O ARK antigo será sobrescrito quando você salvar."

msgid "plugins.pubIds.ark.editor.generateNewArk.confirmNew"
msgstr "Gerar um novo ARK para esta edição?"

msgid "plugins.pubIds.ark.editor.duplicateArkError"
msgstr "ERRO: Este ARK já está em uso por outro artigo ou edição! Use o botão 'Gerar Novo ARK' para criar um identificador único."

msgid "plugins.pubIds.ark.editor.saveSuccess"
msgstr "ARK salvo com sucesso!"

msgid "plugins.pubIds.ark.editor.networkError"
msgstr "Erro de rede. Tente novamente."

msgid "plugins.pubIds.ark.editor.genericError"
msgstr "Erro ao salvar ARK: "

msgid "plugins.pubIds.ark.suffix.random"
msgstr "Sufixo aleatório"

msgid "common.saving"
msgstr "Salvando..."

msgid "plugins.pubIds.ark.validation.invalidNaan"
msgstr "Formato de NAAN inválido. Use 'ark:12345' ou apenas o número."

msgid "plugins.pubIds.ark.validation.naanNotFound"
msgstr "O NAAN '{$naan}' não está registrado na ARK Alliance. Registre-se em: https://forms.gle/2a8HQUNJRAcvq5UGA"

msgid "plugins.pubIds.ark.validation.domainMismatch"
msgstr "Este NAAN pertence ao domínio '{$registered}', mas seu site está em '{$current}'. Para usar este NAAN, atualize seu cadastro na ARK Alliance."

msgid "plugins.pubIds.ark.validation.serverUnavailable"
msgstr "Servidor de validação temporariamente indisponível. Tente novamente mais tarde."

msgid "plugins.pubIds.ark.validation.invalidResponse"
msgstr "Resposta inválida do servidor de validação. Tente novamente."

msgid "plugins.pubIds.ark.resolver.title"
msgstr "Resolvedor ARK"

msgid "plugins.pubIds.ark.resolver.loading"
msgstr "Resolvendo ARK..."