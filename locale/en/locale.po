msgid "plugins.pubIds.ark.displayName"
msgstr "ARK"

msgid "plugins.pubIds.ark.description"
msgstr "Plugin to assign ARK (Archival Resource Key) identifiers to articles and issues."

msgid "plugins.pubIds.ark.manager.settings.description"
msgstr "Configure the ARK plugin:"

msgid "plugins.pubIds.ark.manager.settings.arkObjects"
msgstr "Content types"

msgid "plugins.pubIds.ark.manager.settings.arkObjectsRequired"
msgstr "Select at least one content type (Articles or Issues) to assign ARKs."

msgid "plugins.pubIds.ark.manager.settings.explainARKs"
msgstr "Select which content types will receive ARKs:"

msgid "plugins.pubIds.ark.manager.settings.enablePublicationARK"
msgstr "Articles"

msgid "plugins.pubIds.ark.manager.settings.enableIssueARK"
msgstr "Issues"

msgid "plugins.pubIds.ark.manager.settings.arkPrefix"
msgstr "ARK Prefix (NAAN)"

msgid "plugins.pubIds.ark.manager.settings.arkPrefix.description"
msgstr "Your NAAN prefix (e.g., ark:12345). This must be registered with ARK Alliance."

msgid "plugins.pubIds.ark.manager.settings.form.arkPrefixPattern"
msgstr "The prefix must contain 2-40 characters (letters, numbers, :, _)."

msgid "plugins.pubIds.ark.manager.settings.arkSuffix"
msgstr "Suffix format"

msgid "plugins.pubIds.ark.manager.settings.arkSuffix.description"
msgstr "Configure how the ARK suffix will be generated."

msgid "plugins.pubIds.ark.manager.settings.arkSuffixRandom"
msgstr "Random suffix (e.g., CRL1234-ABCD)"

msgid "plugins.pubIds.ark.manager.settings.arkCustomPrefix"
msgstr "Custom prefix:"

msgid "plugins.pubIds.ark.manager.settings.arkCustomPrefix.validation"
msgstr "(2-6 uppercase letters)"

msgid "plugins.pubIds.ark.manager.settings.form.arkCustomPrefixPattern"
msgstr "The custom prefix must contain 2-6 uppercase letters."

msgid "plugins.pubIds.ark.manager.settings.arkResolver"
msgstr "Resolver URL"

msgid "plugins.pubIds.ark.manager.settings.arkResolver.description"
msgstr "Base URL for ARK resolution (e.g., https://n2t.net/)"

msgid "plugins.pubIds.ark.manager.settings.form.arkResolverRequired"
msgstr "Please provide the resolver URL."

msgid "plugins.pubIds.ark.manager.settings.arkResolver.n2t"
msgstr "n2t.net (Default)"

msgid "plugins.pubIds.ark.manager.settings.arkResolver.custom"
msgstr "Custom resolver:"

msgid "plugins.pubIds.ark.manager.settings.arkResolver.customUrl"
msgstr "Custom resolver URL"

msgid "plugins.pubIds.ark.manager.settings.arkResolver.defaultHint"
msgstr "Leave blank to use default n2t.net resolver"

msgid "plugins.pubIds.ark.manager.settings.preview"
msgstr "Preview"

msgid "plugins.pubIds.ark.manager.settings.previewLabel"
msgstr "Example ARK that will be generated:"

msgid "plugins.pubIds.ark.manager.settings.arkReassign"
msgstr "Reassign ARKs"

msgid "plugins.pubIds.ark.manager.settings.arkReassign.description"
msgstr "Click to remove all existing ARKs and reassign with new settings."

msgid "plugins.pubIds.ark.manager.settings.arkReassign.confirm"
msgstr "Are you sure? All existing ARKs will be permanently removed."

msgid "plugins.pubIds.ark.manager.settings.arkImplementationDate"
msgstr "ARK Implementation Date"

msgid "plugins.pubIds.ark.manager.settings.arkImplementationDate.description"
msgstr "Enter the date when ARK identifiers started being used in your journal."

msgid "plugins.pubIds.ark.manager.settings.arkImplementationDate.recommendation"
msgstr "If this is your first time using ARK, enter the date you received your NAAN or the publication date of the first ARK."

msgid "plugins.pubIds.ark.manager.settings.form.arkImplementationDatePattern"
msgstr "The date must be in YYYYMMDD format (year, month, day) with 8 digits."

msgid "plugins.pubIds.ark.manager.settings.telemetryEnabled"
msgstr "Send anonymous statistics"

msgid "plugins.pubIds.ark.manager.settings.telemetryEnabled.description"
msgstr "Help improve the plugin by sharing anonymous usage data."

msgid "plugins.pubIds.ark.manager.settings.telemetryEnabled.help"
msgstr "Data sent: NAAN, ARK count, plugin version. No personal data is collected. Learn more in the Privacy Policy."

msgid "plugins.pubIds.ark.editor.ark"
msgstr "ARK"

msgid "plugins.pubIds.ark.editor.arkHelp"
msgstr "ARK (Archival Resource Key) is a persistent identifier. Click 'Generate ARK' to automatically create a new identifier."

msgid "plugins.pubIds.ark.editor.missingPrefix"
msgstr "The ARK must begin with {$arkPrefix}."

msgid "plugins.pubIds.ark.editor.invalidSuffixFormat"
msgstr "Invalid format. Use: {$format}"

msgid "plugins.pubIds.ark.editor.arkSuffixNotUnique"
msgstr "This ARK is already in use. Click \"Generate ARK\" to create a new one."

msgid "plugins.pubIds.ark.editor.clearObjectsARK"
msgstr "Clear ARK"

msgid "plugins.pubIds.ark.editor.clearObjectsARK.confirm"
msgstr "Permanently remove this ARK?"

msgid "plugins.pubIds.ark.editor.assignARK"
msgstr "Assign ARK {$pubId} to this {$pubObjectType}"

msgid "plugins.pubIds.ark.editor.ark.assignArk"
msgstr "Assign"

msgid "plugins.pubIds.ark.editor.ark.clearArk"
msgstr "Clear"

msgid "plugins.pubIds.ark.editor.generateArk"
msgstr "Generate ARK"

msgid "plugins.pubIds.ark.editor.generateNewArk"
msgstr "Generate New ARK"

msgid "plugins.pubIds.ark.editor.generateNewArk.confirmReplace"
msgstr "This will replace the existing ARK: %s. Are you sure you want to generate a new one? The old ARK will be overwritten when you save."

msgid "plugins.pubIds.ark.editor.generateNewArk.confirmNew"
msgstr "Generate a new ARK for this issue?"

msgid "plugins.pubIds.ark.editor.duplicateArkError"
msgstr "ERROR: This ARK is already in use by another article or issue! Use the 'Generate New ARK' button to create a unique identifier."

msgid "plugins.pubIds.ark.editor.saveSuccess"
msgstr "ARK saved successfully!"

msgid "plugins.pubIds.ark.editor.networkError"
msgstr "Network error. Please try again."

msgid "plugins.pubIds.ark.editor.genericError"
msgstr "Error saving ARK: "

msgid "plugins.pubIds.ark.suffix.random"
msgstr "Random suffix"

msgid "common.saving"
msgstr "Saving..."

msgid "plugins.pubIds.ark.validation.invalidNaan"
msgstr "Invalid NAAN format. Use 'ark:12345' or just the number."

msgid "plugins.pubIds.ark.validation.naanNotFound"
msgstr "NAAN '{$naan}' is not registered with ARK Alliance. Register at: https://forms.gle/2a8HQUNJRAcvq5UGA"

msgid "plugins.pubIds.ark.validation.domainMismatch"
msgstr "This NAAN belongs to domain '{$registered}', but your site is at '{$current}'. To use this NAAN, update your registration with ARK Alliance."

msgid "plugins.pubIds.ark.validation.serverUnavailable"
msgstr "Validation server is temporarily unavailable. Please try again later."

msgid "plugins.pubIds.ark.validation.invalidResponse"
msgstr "Invalid response from validation server. Please try again."

msgid "plugins.pubIds.ark.resolver.title"
msgstr "ARK Resolver"

msgid "plugins.pubIds.ark.resolver.loading"
msgstr "Resolving ARK..."

msgid "plugins.pubIds.ark.manager.settings.telemetryEnabled.data.naan"
msgstr "NAAN identifier (public)"

msgid "plugins.pubIds.ark.manager.settings.telemetryEnabled.data.count"
msgstr "Number of ARKs generated"

msgid "plugins.pubIds.ark.manager.settings.telemetryEnabled.data.version"
msgstr "Plugin version"

msgid "plugins.pubIds.ark.manager.settings.telemetryEnabled.privacyLink"
msgstr "Privacy Policy"

msgid "plugins.pubIds.ark.validation.rateLimit"
msgstr "Too many validation attempts. You are temporarily blocked."

msgid "plugins.pubIds.ark.validation.domainMismatch"
msgstr "This NAAN does not belong to your domain!"

msgid "plugins.pubIds.ark.validation.notFound"
msgstr "NAAN not found in ARK Alliance registry. Please verify the NAAN is correct."

msgid "plugins.pubIds.ark.validation.missingFields"
msgstr "Missing required fields: NAAN and domain are required."

msgid "plugins.pubIds.ark.validation.invalidFormat"
msgstr "Invalid NAAN format. Use only numbers (e.g., 16081)."

msgid "plugins.pubIds.ark.validation.invalidDomain"
msgstr "Invalid domain format. Please verify the domain is correct."

msgid "plugins.pubIds.ark.validation.methodNotAllowed"
msgstr "Request method not allowed."

msgid "plugins.pubIds.ark.validation.error.generic"
msgstr "Error validating NAAN. Please try again."

msgid "plugins.pubIds.ark.validation.minutesRemaining"
msgstr "minutes remaining"

msgid "plugins.pubIds.ark.validation.tryAgainAfter"
msgstr "Try again after:"

msgid "plugins.pubIds.ark.manager.settings.naanTarget.title"
msgstr "n2t.net Configuration Required"

msgid "plugins.pubIds.ark.manager.settings.naanTarget.description"
msgstr "For your ARKs to resolve correctly, you need to configure your NAAN target on n2t.net with the URL below. This URL must be provided in the NAAN registration or update form:"

msgid "plugins.pubIds.ark.manager.settings.naanTarget.help"
msgstr "If you don't have a NAAN yet, request one at:"

msgid "plugins.pubIds.ark.manager.settings.naanTarget.link"
msgstr "ARK Alliance"

msgid "plugins.pubIds.ark.manager.settings.naanTarget.or"
msgstr "or use the"

