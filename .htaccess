# ARK Plugin - Allows access to the resolver
# This file is necessary for resolver.php to function
# without requiring editing of the main .htaccess

<Files "resolver.php">
    Require all granted
</Files>

# Prevents directory listing for security
Options -Indexes

# Protects sensitive plugin files
<FilesMatch "\.(inc|tpl|po|mo|json|md|txt)$">
    Require all denied
</FilesMatch>

# DON'T DELETE
