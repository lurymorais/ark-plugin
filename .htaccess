<FilesMatch "\.php$">
    Require all denied
</FilesMatch>

<Files "resolver.php">
    Require all granted
</Files>

<Files "save_ajax.php">
    Require all granted
</Files>

<Files "index.php">
    Require all granted
</Files>

<FilesMatch "\.(css|js)$">
    Require all granted
</FilesMatch>

# Impedir listagem de diretórios
Options -Indexes