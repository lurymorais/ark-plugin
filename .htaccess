# ============================================
# ARK PLUGIN - PROTEÇÃO SIMPLIFICADA
# ============================================

# Bloquear acesso a todos os arquivos PHP
<FilesMatch "\.php$">
    Require all denied
</FilesMatch>

# Permitir arquivos essenciais
<Files "resolver.php">
    Require all granted
</Files>

<Files "save_ajax.php">
    Require all granted
</Files>

<Files "index.php">
    Require all granted
</Files>

# Permitir arquivos estáticos
<FilesMatch "\.(css|js)$">
    Require all granted
</FilesMatch>

# Impedir listagem de diretórios
Options -Indexes